# NexusIQ Backend Environment Configuration

# Database Configuration
# Provide either local SQLite or remote PostgreSQL URL
# DATABASE_URL="sqlite+aiosqlite:///./test.db"
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/nexusiq"

# Redis Configuration (For Celery and Caching)
REDIS_URL="redis://localhost:6379/0"

# AI Engine
GEMINI_API_KEY="your-google-gemini-api-key"

# Security (JWT)
SECRET_KEY="replace-this-with-a-secure-random-string"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="1440"

# Logging & Environment
ENVIRONMENT="production"  # or "development"
LOG_LEVEL="INFO"
